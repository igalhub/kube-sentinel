{
  "title": "kube-sentinel",
  "uid": "kube-sentinel-v1",
  "schemaVersion": 36,
  "version": 1,
  "tags": ["kube-sentinel"],
  "timezone": "browser",
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource",
        "label": "Data Source"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Pod Restart Count",
      "description": "Total restarts per container. Climbing values indicate crash-looping.",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum by (namespace, pod) (kube_sentinel_pod_restart_count > 0)",
          "legendFormat": "{{namespace}}/{{pod}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["max"]}
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 5,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "short",
          "min": 0,
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Running Pods",
      "type": "stat",
      "gridPos": {"x": 0, "y": 8, "w": 8, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(kube_sentinel_pod_phase{phase=\"Running\"})",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Pending Pods",
      "type": "stat",
      "gridPos": {"x": 8, "y": 8, "w": 8, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(kube_sentinel_pod_phase{phase=\"Pending\"})",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Failed / Unknown Pods",
      "type": "stat",
      "gridPos": {"x": 16, "y": 8, "w": 8, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(kube_sentinel_pod_phase{phase=~\"Failed|Unknown\"})",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "CrashLoopBackOff Containers",
      "description": "Point-in-time snapshot of the waiting/CrashLoopBackOff label. A container actively crash-looping can briefly read 0 between backoff cycles (K8s only sets this label once the container enters its wait period) -- check Pod Restart Count for the persistent signal, and note the PodCrashLooping alert rule also fires independently on restart rate.",
      "type": "stat",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "count(kube_sentinel_pod_container_state{state=\"waiting\",reason=\"CrashLoopBackOff\"} == 1) or vector(0)",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "OOMKilled Containers",
      "description": "Point-in-time snapshot of the terminated/OOMKilled label -- same caveat as CrashLoopBackOff Containers: a container that already restarted after an OOM kill may show 0 here if it's back in Running state at scrape time.",
      "type": "stat",
      "gridPos": {"x": 12, "y": 12, "w": 12, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "count(kube_sentinel_pod_container_state{state=\"terminated\",reason=\"OOMKilled\"} == 1) or vector(0)",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "title": "Deployment Availability",
      "description": "Desired vs available vs unavailable replicas per deployment.",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 16, "w": 24, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum by (namespace, deployment) (kube_sentinel_deployment_replicas_desired)",
          "legendFormat": "{{namespace}}/{{deployment}} desired",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum by (namespace, deployment) (kube_sentinel_deployment_replicas_available)",
          "legendFormat": "{{namespace}}/{{deployment}} available",
          "refId": "B"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum by (namespace, deployment) (kube_sentinel_deployment_replicas_unavailable)",
          "legendFormat": "{{namespace}}/{{deployment}} unavailable",
          "refId": "C"
        }
      ],
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["last"]}
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 5,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "short",
          "min": 0,
          "color": {"mode": "palette-classic"}
        },
        "overrides": [
          {
            "matcher": {"id": "byRegexp", "options": ".*unavailable"},
            "properties": [
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}
            ]
          }
        ]
      }
    },
    {
      "id": 8,
      "title": "Node Ready",
      "type": "stat",
      "gridPos": {"x": 0, "y": 24, "w": 8, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "min(kube_sentinel_node_ready)",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {"text": "NOT READY", "color": "red", "index": 0},
                "1": {"text": "READY", "color": "green", "index": 1}
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 9,
      "title": "Memory Pressure",
      "type": "stat",
      "gridPos": {"x": 8, "y": 24, "w": 8, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(kube_sentinel_node_condition{condition=\"MemoryPressure\"})",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {"text": "OK", "color": "green", "index": 0},
                "1": {"text": "PRESSURE", "color": "red", "index": 1}
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 10,
      "title": "Disk Pressure",
      "type": "stat",
      "gridPos": {"x": 16, "y": 24, "w": 8, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "sum(kube_sentinel_node_condition{condition=\"DiskPressure\"})",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {"text": "OK", "color": "green", "index": 0},
                "1": {"text": "PRESSURE", "color": "red", "index": 1}
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 11,
      "title": "Node CPU Saturation",
      "description": "Requested CPU as a percentage of allocatable CPU per node.",
      "type": "bargauge",
      "gridPos": {"x": 0, "y": 28, "w": 12, "h": 6},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "kube_sentinel_node_requested_cpu_cores / kube_sentinel_node_allocatable_cpu_cores * 100",
          "legendFormat": "{{node}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color",
        "namePlacement": "auto",
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 90}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 12,
      "title": "Node Memory Saturation",
      "description": "Requested memory as a percentage of allocatable memory per node.",
      "type": "bargauge",
      "gridPos": {"x": 12, "y": 28, "w": 12, "h": 6},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "kube_sentinel_node_requested_memory_bytes / kube_sentinel_node_allocatable_memory_bytes * 100",
          "legendFormat": "{{node}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color",
        "namePlacement": "auto",
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 90}
            ]
          }
        },
        "overrides": []
      }
    }
  ]
}
